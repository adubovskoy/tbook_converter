# Copy to .env and fill in your key:  cp .env.example .env
# Precedence: command-line flags > shell env > .env > built-in defaults.

# ── Backend ───────────────────────────────────────────────────────────────────
# openrouter — metered HTTP API (needs OPENROUTER_API_KEY below).
# claude     — the `claude` CLI in print mode: batches run on your logged-in
#              Claude subscription (OAuth). No API key, no per-token billing —
#              but they do consume your subscription's usage windows. A stray
#              ANTHROPIC_API_KEY is stripped from the CLI's env automatically.
# PROVIDER=openrouter
# CLAUDE_MODEL=claude-haiku-4-5   # model for --provider claude (MODEL below is
                                  # OpenRouter-only and never leaks into claude)
# CLAUDE_BIN=claude               # CLI path override

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution shown on your OpenRouter dashboard:
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=reader-tbook-converter

# ── Model (OpenRouter backend only) ──────────────────────────────────────────
# Exact ids change — verify at https://openrouter.ai/models. Do NOT use Anthropic
# models here (metered Anthropic runs are not wanted — use PROVIDER=claude to run
# Claude models on the subscription instead).
MODEL=google/gemini-2.5-flash           # fast (~2s), cheap, reliable strict JSON — recommended
# Alternatives (uncomment one):
# MODEL=google/gemini-2.5-flash-lite           # even cheaper/faster
# MODEL=deepseek/deepseek-chat-v3.1            # strong multilingual, cheap
# MODEL=qwen/qwen-2.5-72b-instruct             # solid multilingual
# MODEL=mistralai/mistral-small-3.2-24b-instruct
# MODEL=meta-llama/llama-3.3-70b-instruct
# MODEL=google/gemma-4-31b-it                  # tested: slow + dropped ~9% of sentences here

# ── Languages ─────────────────────────────────────────────────────────────────
SOURCE_LANG=en
TARGET_LANG=ru

# ── Pipeline tuning ───────────────────────────────────────────────────────────
BATCH_SIZE=16            # sentences per API request
CONCURRENCY=6            # parallel requests (lower this for :free models)
MAX_RETRIES=4            # per-request retry attempts (network/5xx/429/parse)
TEMPERATURE=0.3
REQUEST_TIMEOUT_SEC=120
USE_JSON_MODE=true       # send response_format=json_object (disable if a model rejects it)
CACHE_DIR=.tbook_cache

# ── OpenRouter provider routing (optional) ──────────────────────────────────
# PROVIDER_SORT=         # throughput | latency | price. Blank = default routing.
                         # For whole-book runs prefer blank/latency: throughput
                         # pins one provider and serializes concurrency (slower).
# PROVIDER_ORDER=        # pin providers by slug, comma-separated (e.g. alibaba)
# NO_LEXCHECK=false      # the free static drift check runs by default; true disables
