# Copy to .env and fill in your key:  cp .env.example .env
# Precedence: command-line flags > shell env > .env > built-in defaults.

# ── Backend ───────────────────────────────────────────────────────────────────
# openrouter — metered HTTP API (needs OPENROUTER_API_KEY below).
# claude     — the `claude` CLI in print mode: batches run on your logged-in
#              Claude subscription (OAuth). No API key, no per-token billing —
#              but they do consume your subscription's usage windows. A stray
#              ANTHROPIC_API_KEY is stripped from the CLI's env automatically.
# ollama     — a local model on an Ollama server (https://ollama.com): free and
#              offline. Needs `ollama serve` running and the model pulled
#              (e.g. `ollama pull translategemma:12b`). No API key.
# llamacpp   — a local llama.cpp server (also accepts "llama.cpp"): free and
#              offline. Start it with e.g.
#              `llama-server -hf ggml-org/gemma-3-4b-it-GGUF -np 2 -c 8192 --jinja`.
#              The served model is adopted automatically; no API key.
# PROVIDER=openrouter
# CLAUDE_MODEL=claude-haiku-4-5   # model for --provider claude (MODEL below is
                                  # OpenRouter-only and never leaks into claude)
# CLAUDE_BIN=claude               # CLI path override

# ── Ollama (local backend) ────────────────────────────────────────────────────
# OLLAMA_MODEL=translategemma:12b            # model for --provider ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1  # Ollama's OpenAI-compatible endpoint
# OLLAMA_API_KEY=                            # only for a reverse proxy that demands one

# ── llama.cpp (local backend) ─────────────────────────────────────────────────
# LLAMACPP_BASE_URL=http://localhost:8080/v1 # llama-server's OpenAI endpoint
# LLAMACPP_MODEL=                            # empty = adopt the served model's name
#                                            # (llama-server ignores the requested id;
#                                            # the name only keys the cache and logs)
# LLAMACPP_API_KEY=                          # only if llama-server runs with --api-key

# With a local backend (ollama/llamacpp), unset tuning vars adapt:
# CONCURRENCY 2 (the server queues requests past its parallel slots —
# OLLAMA_NUM_PARALLEL / llama-server -np — and queued batches burn the request
# timeout), BATCH_SIZE 4 (small local models answer only the first few items
# of a large batch — measured on translategemma: 16 → 1 answer, 8 → 8),
# REQUEST_TIMEOUT_SEC 300 (local generation is slow, esp. on CPU). Ollama's
# default 4096-token context fits these batch sizes; if you raise BATCH_SIZE,
# raise OLLAMA_CONTEXT_LENGTH / llama-server -c along with it.

# ── OpenRouter ────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional attribution shown on your OpenRouter dashboard:
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=reader-tbook-converter

# ── Model (OpenRouter backend only) ──────────────────────────────────────────
# Exact ids change — verify at https://openrouter.ai/models. Do NOT use Anthropic
# models here (metered Anthropic runs are not wanted — use PROVIDER=claude to run
# Claude models on the subscription instead).
MODEL=google/gemini-3.1-flash-lite      # measured best (2026-07 bench): won blind quality judging, p50 ~2.4s/batch, ~$1/book
# MODEL=google/gemini-2.5-flash         # previous default: slightly better word-align coverage (90% vs 88%), ~1.5x the price
# Avoid "cheap" reasoning/multi-provider models (qwen3.5-flash even in the 02-23
# release, deepseek-v4-flash, gpt-oss-120b, thinking variants): hidden reasoning
# inflates output 3-16x and p50 hits 30-100s — measured slower AND costlier than
# the geminis. gemma-3-12b-it drops sentences (16/1041 lost after all retries).

# ── Languages ─────────────────────────────────────────────────────────────────
SOURCE_LANG=en
TARGET_LANG=ru

# ── Pipeline tuning (defaults are the measured optimum — see issue #2) ─
# BATCH_SIZE / CONCURRENCY / REQUEST_TIMEOUT_SEC adapt to the provider when
# left unset (openrouter: 16/32/120; ollama: 4/2/300; claude: 16/32/300) —
# setting one here pins that value for EVERY provider.
# BATCH_SIZE=16            # sentences per API request (bigger is SLOWER: output-bound)
# CONCURRENCY=32           # parallel requests (gemini took 48 with zero 429s; lower for :free models)
MAX_RETRIES=4            # per-request retry attempts (network/5xx/429/parse)
TEMPERATURE=0.3
# REQUEST_TIMEOUT_SEC=120
USE_JSON_MODE=true       # send response_format=json_object (disable if a model rejects it)
CACHE_DIR=.tbook_cache
# ALIGN_MODE=hybrid      # default: free local LaBSE word alignment + LLM fallback for
                         # gated sentences (needs tools/embalign-setup.sh once; without
                         # it the run falls back to llm align). llm | emb | hybrid.
# NO_GLOSSARY=false      # glossary (term-consistency) pass runs by default; true skips
                         # it — also needed to reuse caches from pre-glossary runs.
# JUDGE_SCOPE=flagged    # --judge default scope: flagged (suspects + 5% sample) | all

# ── OpenRouter provider routing (optional) ──────────────────────────────────
# PROVIDER_SORT=         # throughput | latency | price. Blank = default routing.
                         # For whole-book runs prefer blank/latency: throughput
                         # pins one provider and serializes concurrency (slower).
# PROVIDER_ORDER=        # pin providers by slug, comma-separated (e.g. alibaba)
# NO_LEXCHECK=false      # the free static drift check runs by default; true disables
